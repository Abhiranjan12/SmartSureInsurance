    "/api/claims/{claimId}/documents/{documentId}": {
      "delete": {
        "tags": [
          "ClaimDocument"
        ],
        "parameters": [
          {
            "name": "claimId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "documentId",
            "in": "path",
            "required": true,
