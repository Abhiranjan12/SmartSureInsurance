            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateClaimStatusDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateClaimStatusDto"
              }
