            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/claims/{id}/status": {
      "patch": {
        "tags": [
          "Claim"
        ],
        "parameters": [
          {
            "name": "id",
