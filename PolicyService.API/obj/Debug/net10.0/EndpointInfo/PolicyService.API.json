          "customerAge",
          "durationYears",
          "policyTypeId"
        ],
        "type": "object",
        "properties": {
          "policyTypeId": {
            "type": "string",
            "format": "uuid"
          },
          "coverageAmount": {
            "type": "number",
            "format": "double"
          },
          "durationYears": {
            "type": "integer",
            "format": "int32"
          },
          "customerAge": {
            "maximum": 100,
            "minimum": 18,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CalculatePremiumDto": {
