            "format": "int32"
          },
          "coverageAmount": {
            "type": "number",
            "format": "double"
          },
          "durationYears": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "CreatePolicyTypeDto": {
