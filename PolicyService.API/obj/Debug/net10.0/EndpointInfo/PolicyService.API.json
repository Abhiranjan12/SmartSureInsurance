            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "UpdatePolicyTypeDto": {
        "required": [
          "basePremium",
          "coverageYears",
          "description",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "minLength": 1,
            "type": "string"
          },
